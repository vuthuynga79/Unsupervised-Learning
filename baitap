    columns=['id','nameOrig','nameDest'],
    errors='ignore'
)
from sklearn.preprocessing import LabelEncoder

le = LabelEncoder()

df['type'] = le.fit_transform(df['type'])

print(df[['type']].head())

)
df['amount_ratio'] = (
    df['amount']
    /(df['oldbalanceOrg']+1)
)
df['origin_diff'] = (
    df['oldbalanceOrg']
    - df['newbalanceOrig']
)
df['origin_diff'] = (
    df['oldbalanceOrg']
    - df['newbalanceOrig']
)
df['origin_error'] = abs(
    df['amount']
    - df['origin_diff']
)
df['dest_diff'] = (
    df['newbalanceDest']
    - df['oldbalanceDest']
)
df['dest_error'] = abs(
    df['amount']
